// Mr. Kutz — diagrama de datos en español (dbdiagram.io)
// Documentación orientada al negocio. La base real PostgreSQL sigue schema.prisma (nombres en inglés / @@map).

Project MrKutz {
  database_type: 'PostgreSQL'
  Note: 'Barbería: citas, pagos, inventario y gestión del negocio.'
}

Table rol {
  id int [pk, increment]
  nombre varchar(50) [unique, not null]
  descripcion varchar(255)
  creado_en timestamp [default: `now()`]

  Note: 'Valores típicos: admin, barber, client'
}

Table usuario {
  id int [pk, increment]
  correo varchar(255) [unique, not null]
  hash_contrasena varchar(255) [not null]
  rol_id int [not null, ref: > rol.id]
  activo boolean [not null, default: true]
  codigo_restauracion varchar(6)
  codigo_restauracion_expira timestamp
  creado_en timestamp [not null, default: `now()`]
  actualizado_en timestamp [not null]
}

Table cliente {
  id int [pk, increment]
  usuario_id int [unique, ref: > usuario.id]
  nombre varchar(100) [not null]
  apellidos varchar(100) [not null]
  telefono varchar(20)
  correo varchar(255)
  notas text
  creado_en timestamp [not null, default: `now()`]
  actualizado_en timestamp [not null]
}

Table barbero {
  id int [pk, increment]
  usuario_id int [unique, not null, ref: > usuario.id]
  nombre varchar(100) [not null]
  apellidos varchar(100) [not null]
  telefono varchar(20)
  especialidades text[]
  activo boolean [not null, default: true]
  creado_en timestamp [not null, default: `now()`]
  actualizado_en timestamp [not null]
}

Table horario_barbero {
  id int [pk, increment]
  barbero_id int [not null, ref: > barbero.id]
  dia_semana int [not null]
  hora_inicio time [not null]
  hora_fin time [not null]
  disponible boolean [not null, default: true]
  creado_en timestamp [not null, default: `now()`]

  indexes {
    (barbero_id, dia_semana) [unique]
  }
}

Table categoria_servicio {
  id int [pk, increment]
  nombre varchar(100) [unique, not null]
  descripcion varchar(255)
  activo boolean [not null, default: true]
  creado_en timestamp [not null, default: `now()`]
  actualizado_en timestamp [not null]
}

Table servicio {
  id int [pk, increment]
  nombre varchar(150) [not null]
  categoria_id int [ref: > categoria_servicio.id, note: 'Si se borra la categoría, queda en null']
  descripcion text
  precio decimal(10,2) [not null]
  duracion_minutos int [not null]
  activo boolean [not null, default: true]
  creado_en timestamp [not null, default: `now()`]
  actualizado_en timestamp [not null]
}

Table cita {
  id int [pk, increment]
  cliente_id int [not null, ref: > cliente.id]
  barbero_id int [not null, ref: > barbero.id]
  servicio_id int [not null, ref: > servicio.id]
  fecha date [not null]
  hora_inicio time [not null]
  hora_fin time [not null]
  estado varchar(20) [not null, default: 'scheduled', note: 'En BD suele ser scheduled, completed, etc.']
  notas text
  creado_en timestamp [not null, default: `now()`]
  actualizado_en timestamp [not null]
}

Table metodo_pago {
  id int [pk, increment]
  nombre varchar(50) [unique, not null]
  descripcion varchar(255)
  activo boolean [not null, default: true]
}

Table pago {
  id int [pk, increment]
  cita_id int [ref: > cita.id]
  monto decimal(10,2) [not null]
  metodo_pago_id int [ref: > metodo_pago.id, note: 'Restrict al borrar método']
  referencia varchar(100)
  notas text
  creado_por_id int [ref: > usuario.id]
  creado_en timestamp [not null, default: `now()`]
}

Table categoria_producto {
  id int [pk, increment]
  nombre varchar(100) [unique, not null]
  descripcion text
  activo boolean [not null, default: true]
  creado_en timestamp [not null, default: `now()`]
  actualizado_en timestamp [not null]
}

Table producto {
  id int [pk, increment]
  categoria_id int [ref: > categoria_producto.id, note: 'Si se borra la categoría, queda en null']
  nombre varchar(150) [not null]
  descripcion text
  sku varchar(50) [unique]
  unidad varchar(20) [not null, default: 'unit']
  stock_minimo int [not null, default: 0]
  activo boolean [not null, default: true]
  creado_en timestamp [not null, default: `now()`]
  actualizado_en timestamp [not null]
}

Table inventario {
  id int [pk, increment]
  producto_id int [unique, not null, ref: > producto.id]
  cantidad int [not null, default: 0]
  ultima_actualizacion timestamp [not null, default: `now()`]
}

Table movimiento_inventario {
  id int [pk, increment]
  producto_id int [not null, ref: > producto.id]
  cambio_cantidad int [not null]
  tipo_movimiento varchar(20)
  notas text
  creado_por_id int [ref: > usuario.id]
  creado_en timestamp [not null, default: `now()`]
}

Table compra {
  id int [pk, increment]
  proveedor varchar(150)
  numero_factura varchar(80)
  notas text
  importe_total decimal(10,2) [not null, default: 0]
  creado_por_id int [ref: > usuario.id]
  creado_en timestamp [not null, default: `now()`]
  actualizado_en timestamp [not null]
}

Table linea_compra {
  id int [pk, increment]
  compra_id int [not null, ref: > compra.id]
  producto_id int [not null, ref: > producto.id, note: 'Restrict al borrar producto']
  cantidad int [not null]
  costo_unitario decimal(10,2) [not null]
  subtotal decimal(10,2) [not null, default: 0]
  creado_en timestamp [not null, default: `now()`]
}

Table configuracion_negocio {
  id int [pk, increment]
  nombre_negocio varchar(150) [not null, default: 'Mr. Kutz']
  url_logo varchar(500)
  color_primario varchar(20)
  color_secundario varchar(20)
  correo_contacto varchar(255)
  telefono_contacto varchar(50)
  direccion text
  horario_apertura text
  actualizado_en timestamp [not null, default: `now()`]

  Note: 'Normalmente una sola fila (id = 1)'
}

Table testimonio {
  id int [pk, increment]
  nombre_autor varchar(100) [not null]
  rol_autor varchar(50)
  contenido varchar(1000) [not null]
  activo boolean [not null, default: true]
  orden int [not null, default: 0]
  creado_en timestamp [not null, default: `now()`]
  actualizado_en timestamp [not null]
}

// Relaciones vía ref:. Implementación real: ver prisma/schema.prisma y migraciones.
