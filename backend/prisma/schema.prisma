generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PurchaseStatus {
  draft
  ordered
  partially_received
  received
  cancelled
}

enum InventoryMovementType {
  purchase
  sale
  adjustment
  damage
  reversal
}

enum InventorySourceType {
  goods_receipt
  payment
  manual_adjustment
  reversal
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  users       User[]
}

model User {
  id                       Int                 @id @default(autoincrement())
  email                    String              @unique @db.VarChar(255)
  passwordHash             String              @map("password_hash") @db.VarChar(255)
  roleId                   Int                 @map("role_id")
  isActive                 Boolean             @default(true) @map("is_active")
  resetCode                String?             @map("reset_code") @db.VarChar(255)
  resetCodeExpires         DateTime?           @map("reset_code_expires")
  resetCodeAttempts        Int                 @default(0) @map("reset_code_attempts")
  createdAt                DateTime            @default(now()) @map("created_at")
  updatedAt                DateTime            @updatedAt @map("updated_at")
  barber                   Barber?
  client                   Client?
  inventoryMovements       InventoryMovement[] @relation("MovementsCreated")
  inventoryMovementsVoided InventoryMovement[] @relation("MovementsVoided")
  paymentsCreated          Payment[]           @relation("PaymentsCreated")
  purchasesCreated         Purchase[]          @relation("PurchasesCreated")
  purchasesCancelled       Purchase[]          @relation("PurchasesCancelled")
  suppliersCreated         Supplier[]          @relation("SuppliersCreated")
  goodsReceiptsCreated     GoodsReceipt[]      @relation("GoodsReceiptsCreated")
  role                     Role                @relation(fields: [roleId], references: [id])
}

model Client {
  id             Int           @id @default(autoincrement())
  userId         Int?          @unique @map("user_id")
  firstName      String        @map("first_name") @db.VarChar(100)
  lastName       String        @map("last_name") @db.VarChar(100)
  phone          String?       @db.VarChar(20)
  email          String?       @db.VarChar(255)
  documentType   String?       @map("document_type") @db.VarChar(40)
  documentNumber String?       @map("document_number") @db.VarChar(80)
  notes          String?       @db.VarChar(500)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  appointments   Appointment[]
  user           User?         @relation(fields: [userId], references: [id])
}

model Barber {
  id             Int              @id @default(autoincrement())
  userId         Int              @unique @map("user_id")
  firstName      String           @map("first_name") @db.VarChar(100)
  lastName       String           @map("last_name") @db.VarChar(100)
  phone          String?          @db.VarChar(20)
  documentType   String?          @map("document_type") @db.VarChar(40)
  documentNumber String?          @map("document_number") @db.VarChar(80)
  specialties    String[]         @default([])
  isActive       Boolean          @default(true) @map("is_active")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  appointments   Appointment[]
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules      BarberSchedule[]
}

model BarberSchedule {
  id          Int      @id @default(autoincrement())
  barberId    Int      @map("barber_id")
  dayOfWeek   Int      @map("day_of_week")
  startTime   DateTime @map("start_time") @db.Time(6)
  endTime     DateTime @map("end_time") @db.Time(6)
  isAvailable Boolean  @default(true) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")
  barber      Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, dayOfWeek])
  @@map("barber_schedules")
}

model Service {
  id              Int              @id @default(autoincrement())
  name            String           @db.VarChar(150)
  categoryId      Int?             @map("category_id")
  category        ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  description     String?
  price           Decimal          @db.Decimal(10, 2)
  durationMinutes Int              @map("duration_minutes")
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  appointments    Appointment[]
}

model ServiceCategory {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(100)
  description String?   @db.VarChar(255)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  services    Service[]

  @@map("service_categories")
}

model Appointment {
  id                  Int       @id @default(autoincrement())
  clientId            Int       @map("client_id")
  barberId            Int       @map("barber_id")
  serviceId           Int       @map("service_id")
  appointmentDate     DateTime  @map("appointment_date") @db.Date
  startTime           DateTime  @map("start_time") @db.Time(6)
  endTime             DateTime  @map("end_time") @db.Time(6)
  status              String    @default("scheduled") @db.VarChar(20)
  notes               String?
  /// Valoración del cliente tras cita completada (1–5); una vez por cita
  clientRating        Int?      @map("client_rating")
  clientRatingComment String?   @map("client_rating_comment") @db.VarChar(2000)
  clientRatedAt       DateTime? @map("client_rated_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  barber              Barber    @relation(fields: [barberId], references: [id], onDelete: Cascade)
  client              Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service             Service   @relation(fields: [serviceId], references: [id])
  payments            Payment[]
}

model PaymentMethod {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(50)
  description String?   @db.VarChar(255)
  isActive    Boolean   @default(true) @map("is_active")
  payments    Payment[]

  @@map("payment_methods")
}

model Payment {
  id                 Int                 @id @default(autoincrement())
  appointmentId      Int?                @map("appointment_id")
  productId          Int?                @map("product_id")
  productQuantity    Int?                @map("product_quantity")
  amount             Decimal             @db.Decimal(10, 2)
  paymentMethodId    Int?                @map("payment_method_id")
  reference          String?             @db.VarChar(100)
  notes              String?
  createdBy          Int?                @map("created_by")
  createdAt          DateTime            @default(now()) @map("created_at")
  voidedAt           DateTime?           @map("voided_at")
  voidReason         String?             @map("void_reason") @db.VarChar(500)
  voidedBy           Int?                @map("voided_by")
  appointment        Appointment?        @relation(fields: [appointmentId], references: [id])
  product            Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)
  creator            User?               @relation("PaymentsCreated", fields: [createdBy], references: [id])
  paymentMethod      PaymentMethod?      @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict)
  inventoryMovements InventoryMovement[]
}

model Product {
  id                 Int                 @id @default(autoincrement())
  categoryId         Int?                @map("category_id")
  name               String              @db.VarChar(150)
  description        String?
  sku                String?             @unique @db.VarChar(50)
  retailPrice        Decimal?            @map("retail_price") @db.Decimal(10, 2)
  costPrice          Decimal?            @map("cost_price") @db.Decimal(10, 2)
  unit               String              @default("unit") @db.VarChar(20)
  minStock           Int                 @default(0) @map("min_stock")
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  category           ProductCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  inventory          Inventory?
  inventoryMovements InventoryMovement[]
  purchaseItems      PurchaseItem[]
  payments           Payment[]
}

model Inventory {
  id          Int      @id @default(autoincrement())
  productId   Int      @unique @map("product_id")
  quantity    Int      @default(0)
  lastUpdated DateTime @default(now()) @map("last_updated")
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model InventoryMovement {
  id                   Int                    @id @default(autoincrement())
  productId            Int                    @map("product_id")
  quantityChange       Int                    @map("quantity_change")
  movementType         InventoryMovementType? @map("movement_type")
  sourceType           InventorySourceType?   @map("source_type")
  goodsReceiptItemId   Int?                   @unique @map("goods_receipt_item_id")
  paymentId            Int?                   @map("payment_id")
  reversalOfMovementId Int?                   @unique @map("reversal_of_movement_id")
  notes                String?
  createdBy            Int?                   @map("created_by")
  createdAt            DateTime               @default(now()) @map("created_at")
  voidedAt             DateTime?              @map("voided_at")
  voidReason           String?                @map("void_reason")
  voidedBy             Int?                   @map("voided_by")
  creator              User?                  @relation("MovementsCreated", fields: [createdBy], references: [id], onDelete: SetNull)
  voider               User?                  @relation("MovementsVoided", fields: [voidedBy], references: [id], onDelete: SetNull)
  product              Product                @relation(fields: [productId], references: [id], onDelete: Restrict)
  goodsReceiptItem     GoodsReceiptItem?      @relation(fields: [goodsReceiptItemId], references: [id], onDelete: Restrict)
  payment              Payment?               @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  reversalOfMovement   InventoryMovement?     @relation("MovementReversal", fields: [reversalOfMovementId], references: [id], onDelete: Restrict)
  reversalMovement     InventoryMovement?     @relation("MovementReversal")

  @@index([productId, createdAt])
  @@index([paymentId])
  @@map("InventoryMovement")
}

model ProductCategory {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(100)
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  products    Product[]

  @@map("product_categories")
}

model Supplier {
  id             Int        @id @default(autoincrement())
  name           String     @db.VarChar(150)
  normalizedName String     @unique @map("normalized_name") @db.VarChar(150)
  taxId          String?    @unique @map("tax_id") @db.VarChar(50)
  contactName    String?    @map("contact_name") @db.VarChar(150)
  email          String?    @db.VarChar(255)
  phone          String?    @db.VarChar(30)
  address        String?    @db.VarChar(500)
  notes          String?    @db.VarChar(1000)
  isActive       Boolean    @default(true) @map("is_active")
  createdBy      Int?       @map("created_by")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  creator        User?      @relation("SuppliersCreated", fields: [createdBy], references: [id], onDelete: SetNull)
  purchases      Purchase[]

  @@index([isActive, name])
  @@map("suppliers")
}

model Purchase {
  id            Int            @id @default(autoincrement())
  supplierId    Int            @map("supplier_id")
  supplierName  String?        @map("supplier_name") @db.VarChar(150)
  orderNumber   String         @unique @map("order_number") @db.VarChar(80)
  invoiceNumber String?        @map("invoice_number") @db.VarChar(80)
  status        PurchaseStatus @default(draft)
  orderedAt     DateTime?      @map("ordered_at")
  expectedAt    DateTime?      @map("expected_at")
  notes         String?
  totalAmount   Decimal        @default(0) @map("total_amount") @db.Decimal(10, 2)
  createdBy     Int?           @map("created_by")
  voidedAt      DateTime?      @map("voided_at")
  voidReason    String?        @map("void_reason") @db.VarChar(500)
  voidedBy      Int?           @map("voided_by")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  creator       User?          @relation("PurchasesCreated", fields: [createdBy], references: [id], onDelete: SetNull)
  cancelledBy   User?          @relation("PurchasesCancelled", fields: [voidedBy], references: [id], onDelete: SetNull)
  supplier      Supplier       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items         PurchaseItem[]
  receipts      GoodsReceipt[]

  @@index([supplierId, status])
  @@index([status, createdAt])
  @@map("purchases")
}

model PurchaseItem {
  id               Int                @id @default(autoincrement())
  purchaseId       Int                @map("purchase_id")
  productId        Int                @map("product_id")
  quantity         Int
  receivedQuantity Int                @default(0) @map("received_quantity")
  unitCost         Decimal            @map("unit_cost") @db.Decimal(10, 2)
  subtotal         Decimal            @default(0) @db.Decimal(10, 2)
  createdAt        DateTime           @default(now()) @map("created_at")
  product          Product            @relation(fields: [productId], references: [id], onDelete: Restrict)
  purchase         Purchase           @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  receiptItems     GoodsReceiptItem[]

  @@index([purchaseId, productId])
  @@map("purchase_items")
}

model GoodsReceipt {
  id            Int                @id @default(autoincrement())
  purchaseId    Int                @map("purchase_id")
  receiptNumber String             @unique @map("receipt_number") @db.VarChar(80)
  receivedAt    DateTime           @default(now()) @map("received_at")
  notes         String?            @db.VarChar(1000)
  createdBy     Int?               @map("created_by")
  createdAt     DateTime           @default(now()) @map("created_at")
  purchase      Purchase           @relation(fields: [purchaseId], references: [id], onDelete: Restrict)
  creator       User?              @relation("GoodsReceiptsCreated", fields: [createdBy], references: [id], onDelete: SetNull)
  items         GoodsReceiptItem[]

  @@index([purchaseId, receivedAt])
  @@map("goods_receipts")
}

model GoodsReceiptItem {
  id             Int                @id @default(autoincrement())
  goodsReceiptId Int                @map("goods_receipt_id")
  purchaseItemId Int                @map("purchase_item_id")
  quantity       Int
  unitCost       Decimal            @map("unit_cost") @db.Decimal(10, 2)
  createdAt      DateTime           @default(now()) @map("created_at")
  goodsReceipt   GoodsReceipt       @relation(fields: [goodsReceiptId], references: [id], onDelete: Restrict)
  purchaseItem   PurchaseItem       @relation(fields: [purchaseItemId], references: [id], onDelete: Restrict)
  movement       InventoryMovement?

  @@unique([goodsReceiptId, purchaseItemId])
  @@index([purchaseItemId])
  @@map("goods_receipt_items")
}

model BusinessSetting {
  id             Int      @id @default(autoincrement())
  businessName   String   @default("Mr. Kutz") @map("business_name") @db.VarChar(150)
  logoUrl        String?  @map("logo_url") @db.VarChar(500)
  primaryColor   String?  @map("primary_color") @db.VarChar(20)
  secondaryColor String?  @map("secondary_color") @db.VarChar(20)
  contactEmail   String?  @map("contact_email") @db.VarChar(255)
  contactPhone   String?  @map("contact_phone") @db.VarChar(50)
  address        String?
  openingHours   String?  @map("opening_hours")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("business_settings")
}

/// Textos curados para la landing pública; no sustituyen la valoración operativa en Appointment.
model Testimonial {
  id         Int      @id @default(autoincrement())
  authorName String   @map("author_name") @db.VarChar(100)
  authorRole String?  @map("author_role") @db.VarChar(50)
  content    String   @db.VarChar(1000)
  isActive   Boolean  @default(true) @map("is_active")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("testimonials")
}
