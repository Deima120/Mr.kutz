{
  "name": "mr-kutz-backend",
  "version": "1.0.0",
  "description": "API REST para sistema de gestión de barbería",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:pull": "prisma db pull",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "create-admin": "node scripts/create-admin.mjs",
    "remove-demo-users": "node scripts/remove-demo-users.mjs",
    "mail:test": "node scripts/probar-correo.mjs",
    "inventory:audit": "node scripts/audit-inventory-consistency.mjs",
    "cron:appointment-status": "node src/jobs/runAppointmentStatusSync.js",
    "test": "node --test src/services/inventory.helpers.test.js src/services/product.rules.test.js src/services/product.dossier.helpers.test.js src/services/purchase.helpers.test.js src/services/purchase.workflow.test.js src/services/supplier.service.test.js",
    "test:inventory": "node --test src/services/inventory.helpers.test.js src/services/product.dossier.helpers.test.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.4",
    "pg": "^8.11.3",
    "resend": "^6.10.0",
    "validator": "^13.12.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
