# Base de datos
# Cada desarrollador copia este archivo a .env y pone su propia DATABASE_URL (Neon u otro PostgreSQL).
DATABASE_URL="postgresql://usuario:clave@host:5432/nombre_db?sslmode=require"
# Neon: URL “Pooled” desde el panel. Si falla: &connect_timeout=30 al final.
# Si ves “Timed out fetching a new connection from the connection pool”: usa URL pooled,
# un solo proceso de API, y opcionalmente &pool_timeout=30 (Prisma/Postgres).
# Opcional: DB_CONNECT_RETRIES=8  DB_CONNECT_RETRY_MS=3000
#
# Prisma — desarrollo con BD ya poblada o sin historial limpio de migrate:
#   cd backend && npx prisma db push && npx prisma generate
# Producción / CI con migraciones aplicadas:
#   npx prisma migrate deploy && npx prisma generate

# Servidor
# PORT=5000
# CORS: orígenes de producción (además de localhost). Lista separada por comas.
# FRONTEND_URL=https://tu-dominio.com,https://www.tu-dominio.com
# Opcional: URL base del frontend usada en correos (por ejemplo enlaces de reseña).
# Si no se define, se usa la primera de FRONTEND_URL.
# PUBLIC_FRONTEND_URL=https://tu-dominio.com
# Permitir previews *.vercel.app y *.netlify.app (útil en staging). Default: false.
# CORS_ALLOW_PREVIEWS=false

# JWT
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
# JWT_EXPIRES_IN=7d

# =============================================================================
# CORREO EN PRODUCCIÓN (Render / Vercel)
# =============================================================================
# Gmail SMTP NO funciona bien en Render (timeout). Para que CUALQUIER usuario
# registrado reciba el código de recuperación, usa una de estas opciones:
#
# OPCIÓN A — Brevo (recomendada, gratis, funciona en Render):
#   1. Crea cuenta en https://www.brevo.com
#   2. SMTP & API → Claves SMTP → genera clave
#   3. En Render pon:
#      MAIL_PROVIDER=smtp
#      SMTP_HOST=smtp-relay.brevo.com
#      SMTP_PORT=587
#      SMTP_SECURE=false
#      SMTP_USER=tu-correo-de-login-brevo
#      SMTP_PASS=xsmtpsib-xxxxxxxx
#      SMTP_FROM="Mr. Kutz <noreply@tudominio.com>"
#   4. Deja RESEND_API_KEY vacío o quita onboarding@resend.dev
#
# OPCIÓN B — Resend con dominio verificado:
#   1. Verifica tu dominio en https://resend.com/domains
#   2. RESEND_API_KEY=re_xxxx
#   3. RESEND_FROM=noreply@tudominio.com
#   4. MAIL_PROVIDER=resend
#
# Desarrollo local: Gmail SMTP funciona (abajo).

MAIL_PROVIDER=
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="tu-correo@gmail.com"
SMTP_PASS="contraseña-de-aplicacion-gmail"
# SMTP_FROM="Mr. Kutz <tu-correo@gmail.com>"

# Crear administrador real (no va en el seed). Tras npm run db:seed:
# ADMIN_EMAIL=tu-correo@dominio.com
# ADMIN_PASSWORD=TuClaveSegura1
# npm run create-admin
#
# Quitar cuentas demo antiguas (@mrkutz.com del seed viejo):
# npm run remove-demo-users

# NODE_ENV=production