{
  "name": "mr-kutz-barbershop",
  "version": "1.0.0",
  "description": "Sistema profesional de gestión para barbería",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "build": "cd frontend && npm run build",
    "start": "cd backend && npm start",
    "seed:admin": "cd backend && node scripts/seed-admin.js"
  },
  "keywords": ["barbershop", "management", "react", "express", "postgresql"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
