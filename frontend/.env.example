# URL base de la API (sin barra final).
# Desarrollo con Vite: suele bastar con /api (proxy en vite.config.js → localhost:5000).
VITE_API_URL=/api

# Producción (ejemplo): descomenta y ajusta al dominio real del backend.
# VITE_API_URL=https://mrkutz-backend.onrender.com/api

# Enlaces de descarga de la app móvil (Flutter). Deja vacío lo que aún no tengas publicado.
# VITE_MOBILE_APP_IOS_URL=https://apps.apple.com/app/idXXXXXXXXX
# VITE_MOBILE_APP_ANDROID_URL=https://play.google.com/store/apps/details?id=com.mrkutz.app
# Google Drive: sube el APK, comparte como "Cualquier persona con el enlace" y pega el enlace aquí.
# VITE_MOBILE_APP_DRIVE_URL=https://drive.google.com/file/d/TU_FILE_ID/view?usp=sharing
# VITE_MOBILE_APP_APK_URL=https://tu-dominio.com/downloads/mrkutz.apk
